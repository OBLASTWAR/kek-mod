#pragma once
// Copy this file to KekSecrets.h (gitignored, next to this one) and fill in
// the real value -- ask a maintainer, or check GDR's application.yml
// (kek.api-key) if you run your own server.
//
// This is a spam/scanner barrier, not real secrecy: it ships inside a
// public DLL, so anyone can pull it back out with `strings` on the binary.
// Keeping it out of source control just keeps it off GitHub's public diff
// and out of automated secret scanners -- it doesn't (and can't) keep it
// out of the compiled mod itself.
#define KEKMOD_API_KEY  ""
